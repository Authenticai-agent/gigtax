{
  "_meta": {
    "purpose": "Per-state capital-gains treatment for a future state layer on the Phase 11 investment calculators (capital gains, dividends, interest, crypto). The federal calculators ship WITHOUT this layer; it turns on only when this file is filled and signed off.",
    "status": "SKELETON — all values null, awaiting owner research and sign-off. Nothing here is used by the site yet.",
    "verified": null,
    "signedOffBy": null,
    "rule": "No figure enters this file without a source URL on a state government or revenue-department domain. A null is a correct, expected value; a guessed number is not. This is exactly what the never-invent rule in CLAUDE.md covers — capital-gains treatment varies by state in ways a general income-tax rate does not capture.",
    "whyThisIsNeeded": "A naive 'apply the state's ordinary income rate to gains' is wrong in three ways the dataset must capture: (1) Washington has NO income tax but DOES levy a standalone excise on long-term gains — applying the ordinary rate gives $0 when the real answer is 7%; (2) several states exclude part of long-term gains from tax (e.g. reported figures around 44% in South Carolina, 30% in Wisconsin, plus Arkansas, Hawaii, New Mexico, North Dakota, Montana, Vermont) — the ordinary rate overstates them; (3) a few states tax short-term and long-term gains differently. Each of these needs a verified per-state figure.",
    "schema": {
      "<STATE>": {
        "treatment": "'ordinary' | 'excluded' | 'special' | 'none' | null — 'ordinary' = gains taxed at the state's normal income rate; 'excluded' = a percentage of long-term gain is exempt; 'special' = a standalone rate distinct from income tax (Washington); 'none' = the state has no tax on this gain.",
        "ordinaryRateApplies": "boolean|null — true when the state taxes the gain at its ordinary income rate (the calculator can then reuse calcStateTax).",
        "ltcgExclusionPct": "number|null — fraction of LONG-TERM gain excluded from state tax, 0..1. Only when treatment='excluded'.",
        "specialRate": "number|null — a flat standalone rate on gains, e.g. Washington. Only when treatment='special'.",
        "specialRateThreshold": "number|null — the gain amount above which specialRate applies (Washington exempts a large annual amount).",
        "shortTermTreatment": "'ordinary' | 'same_as_long' | null — how short-term gains are taxed if it differs from long-term.",
        "source": "string|null — URL on a state government / revenue-department domain.",
        "confidence": "'high'|'medium'|'low'|null",
        "note": "string|null — anything the numbers cannot carry (annual exemptions, brackets on the special rate, credits)."
      }
    }
  },
