---
/**
 * Base layout: <head> management, self-referencing canonical derived from
 * Astro.site (the single SITE_URL), brand header, and the footer disclaimer.
 * Zero JavaScript ships from this layout — islands opt in per page.
 */
import '../styles/global.css';
import { SITE_INDEXABLE } from '../site';
import { faqJsonLd, type FaqItem } from '../lib/faq';
import fontCss from '../styles/google-fonts.css?raw';

interface Props {
  title: string;
  description: string;
  faqItems?: FaqItem[];
}
const { title, description, faqItems } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const faqLd = faqItems && faqItems.length ? faqJsonLd(faqItems) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={SITE_INDEXABLE ? 'index,follow' : 'noindex,nofollow'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {faqLd && <script type="application/ld+json" set:html={faqLd} />}
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style set:html={fontCss}></style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo"><span class="logo-accent">MoneyScope</span>Calculators</a>
        <nav class="main-nav">
          <a href="/1099-tax-calculator/">1099</a>
          <a href="/quarterly-tax-calculator/">Quarterly</a>
          <a href="/paycheck-calculator/">Paycheck</a>
          <a href="/s-corp-tax-calculator/">S-corp</a>
          <a href="/rsu-tax-calculator/">Equity</a>
          <a href="/capital-gains-tax-calculator/">Investments</a>
          <a href="/inheritance-tax-calculator/">Inheritance</a>
          <a href="/gig-tax-calculator/">Gig</a>
          <a href="/cross-border-tax/">Two states</a>

          <a href="/benefits-tax-calculator/">Benefits</a>
          <a href="/local-income-tax/">Local tax</a>
          <a href="/business-deductions/">By profession</a>
          <a href="/personal-finance/">Money</a>
          <a href="/lifestyle/">Lifestyle</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p class="disclaimer">
        For informational purposes only. Not tax advice. 2026 tax year figures.
        Verify with <a href="https://www.irs.gov" rel="noopener">IRS.gov</a> or a
        qualified tax professional before filing. · MoneyScopeCalculators
      </p>
    </footer>
  </body>
</html>
