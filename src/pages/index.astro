---
import Base from '../layouts/Base.astro';
import QuickEstimator from '../components/calculators/QuickEstimator.tsx';
import { VERIFIED, LAST_VERIFIED } from '../data/federal';
import { stateList } from '../data/states';
import { stateSlug } from '../lib/slug';
---

<Base
  title="MoneyScope — 2026 tax calculators for 1099, gig, and self-employed income"
  description="Free 2026 tax calculators. Estimate self-employment tax, federal and state income tax, and what to set aside — with figures verified from IRS sources."
>
  <section class="hero">
    <p class="hero-label">2026 tax year · verified {LAST_VERIFIED}</p>
    <h1>Tax calculators for people who <em>work for themselves</em></h1>
    <p class="tagline">Self-employment tax, federal and state income tax, and what to set aside — in one place.</p>
  </section>

  <p>
    Every figure comes from the verified 2026 dataset (<code>{VERIFIED}</code>) — the same
    numbers that drive the worked examples on each page.
  </p>

  <p class="section-label">Quick estimate</p>
  <QuickEstimator client:load defaultSeIncome={50000} stateHrefBase="/1099-tax-calculator/" />

  <h2>Living and working in different states</h2>
  <p>
    Commute across a state line? See <a href="/cross-border-tax/">which
    state taxes your wages</a> — reciprocity agreements, nonresident returns, and credits
    for every bordering-state pair.
  </p>

  <h2>1099 tax calculator by state</h2>
  <p>Pick your state for a page built on that state's 2026 income tax rules:</p>
  <ul class="link-columns">
    {stateList.map(([, s]) => (
      <li><a href={`/1099-tax-calculator/${stateSlug(s.name)}/`}>{s.name}</a></li>
    ))}
  </ul>
</Base>
