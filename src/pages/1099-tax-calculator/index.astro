---
import Base from '../../layouts/Base.astro';
import QuickEstimator from '../../components/calculators/QuickEstimator.tsx';
import { stateList } from '../../data/states';
import { stateSlug, describeSelfEmploymentTax } from '../../lib/state-copy';
---

<Base
  title="1099 tax calculator (2026) — self-employment & income tax estimate"
  description="Estimate 2026 taxes on 1099 income: self-employment tax, federal income tax, and your state's income tax. Free, no sign-up, figures verified from IRS sources."
>
  <section class="hero">
    <p class="hero-label">2026 tax year</p>
    <h1>1099 tax calculator</h1>
    <p class="tagline">No tax is withheld on 1099 income — estimate what you'll owe and set it aside.</p>
  </section>

  <p>
    If you're paid on a 1099, you owe self-employment tax (15.3% on 92.35% of net
    profit) plus federal and state income tax. This calculator estimates all three.
  </p>

  <QuickEstimator client:load defaultSeIncome={50000} stateHrefBase="/1099-tax-calculator/" />

  <h2>How self-employment tax is built</h2>
  <p data-source="data/federal.ts → federal.selfEmployment">{describeSelfEmploymentTax()}</p>
  <p>
    This federal layer is identical in all 51 jurisdictions. What changes from
    state to state is the income tax stacked on top of it — which is what each
    state page below works out.
  </p>

  <h2>Choose your state</h2>
  <p>Each state page is built on that state's 2026 income tax rules with a worked example:</p>
  <ul class="link-columns">
    {stateList.map(([code, s]) => (
      <li><a href={`/1099-tax-calculator/${stateSlug(s.name)}/`}>1099 taxes in {s.name}</a></li>
    ))}
  </ul>

  <h2>Going freelance after a layoff?</h2>
  <p>If 1099 work is your bridge after losing a job, size up the whole transition first:</p>
  <ul class="link-columns">
    <li><a href="/severance-pay-tax-calculator/">Severance pay tax</a> — what the flat 22% withholding really costs</li>
    <li><a href="/unemployment-benefits-calculator/">Unemployment benefits</a> — while you build the client base</li>
    <li><a href="/layoff-runway-calculator/">Layoff runway</a> — how long your money lasts</li>
  </ul>
</Base>
