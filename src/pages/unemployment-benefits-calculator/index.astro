---
/** Layoff cluster: unemployment benefits calculator (national hub). */
import Base from '../../layouts/Base.astro';
import LayoffProgress from '../../components/LayoffProgress.astro';
import UnemploymentCalculator from '../../components/calculators/UnemploymentCalculator.tsx';
import { uiBenefit } from '../../lib/layoff/uiBenefit';
import { formatMoney } from '../../lib/tax-engine';

const wa = uiBenefit({ stateCode: 'WA', priorAnnualWage: 90000, dependents: 0 });
const fl = uiBenefit({ stateCode: 'FL', priorAnnualWage: 90000, dependents: 0 });

const faqItems = [
  { q: `Is unemployment taxable?`, a: `Federally, yes — it's ordinary income, and you can elect 10% withholding on Form W-4V. Most states tax it too, but a handful (including California, New Jersey, and Pennsylvania) do not. The calculator shows your state's treatment, which matters for your runway.`, review: true },
  { q: `Does severance delay my unemployment?`, a: `In some states, yes — severance can delay or reduce benefits while it's being paid; in others it's ignored. The rule varies enough that we flag it rather than compute it. Confirm the timing with your state agency before you file, because when you file is a real-money decision.`, review: true },
  { q: `Is this my exact benefit?`, a: `No — it's a planning estimate (roughly half your average weekly wage, capped at your state's maximum). Your state agency applies the precise formula on your actual wage history. Use their calculator for the official figure and file through their site.`, review: false },
];
---

<Base
  title="Unemployment benefits calculator 2026 — amount and duration"
  description="Estimate your weekly unemployment benefit and how many weeks you'll get, by state, for 2026 — plus the tax treatment and the severance-timing trap."
  faqItems={faqItems}
>
  <section class="hero">
    <p class="hero-label">2026 tax year · laid off</p>
    <h1>Unemployment benefits calculator</h1>
    <p class="tagline">What you'll get a week, for how many weeks, and whether it's taxed — the range runs from $235 (Mississippi) to $1,208 (Washington). Pick your state.</p>
  </section>

  <LayoffProgress active="unemployment" />

  <p>
    Unemployment benefits vary enormously by state — in both the weekly amount and the number of weeks. This
    estimates your weekly benefit from your prior wage, bounded by your state's own minimum and maximum, and shows the
    duration, the waiting week, the tax treatment, and the severance-timing note that can cost real money if you claim
    at the wrong moment. It's an estimate; your state agency runs the exact formula.
  </p>

  <UnemploymentCalculator client:load />

  <h2>Two states, same $90,000 earner</h2>
  <table class="data-table">
    <thead><tr><th>State</th><th>Weekly (est.)</th><th>Weeks</th><th>Total potential</th></tr></thead>
    <tbody>
      <tr><td>Washington</td><td>{formatMoney(wa.estimatedWeeklyBenefit)}</td><td>{wa.durationWeeks}</td><td>{formatMoney(wa.totalPotential)}</td></tr>
      <tr><td>Florida</td><td>{formatMoney(fl.estimatedWeeklyBenefit)}</td><td>{fl.durationWeeks}</td><td>{formatMoney(fl.totalPotential)}</td></tr>
    </tbody>
  </table>
  <p>
    The same earner gets {formatMoney(wa.totalPotential)} of potential benefits in Washington but only
    {' '}{formatMoney(fl.totalPotential)} in Florida — Washington pays up to {formatMoney(wa.maxWeekly)} for
    {wa.durationWeeks} weeks, Florida caps at {formatMoney(fl.maxWeekly)} for just {fl.durationWeeks}. Where you claim
    matters as much as what you earned.
  </p>

  <h2>Questions</h2>
  {faqItems.map((f) => (
    <div class="faq">
      <h3>{f.q}</h3>
      <p data-review={f.review ? 'legal' : undefined} set:html={f.a}></p>
    </div>
  ))}

  <h2>Unemployment by state</h2>
  <p>Every state has its own weekly maximum, duration, and rules. Your state page has the exact figures and filing link.</p>

  <h2>Next steps</h2>
  <ul class="link-columns">
    <li><a href="/layoff-runway-calculator/">Runway</a> — how long the benefit stretches your money</li>
    <li><a href="/severance-pay-tax-calculator/">Severance tax</a></li>
    <li><a href="/cobra-vs-marketplace-calculator/">Health coverage</a></li>
  </ul>

  <p class="results-note">An estimate — your state agency determines your actual benefit. Nothing you enter is stored or sent anywhere. Not tax or legal advice.</p>
</Base>
