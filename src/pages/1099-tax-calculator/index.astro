---
import Base from '../../layouts/Base.astro';
import QuickEstimator from '../../components/calculators/QuickEstimator.tsx';
import { stateList } from '../../data/states';
---

<Base
  title="1099 tax calculator (2026) — self-employment & income tax estimate"
  description="Estimate 2026 taxes on 1099 income: self-employment tax, federal income tax, and your state's income tax. Free, no sign-up, figures verified from IRS sources."
>
  <section class="hero">
    <p class="hero-label">2026 tax year</p>
    <h1>1099 tax calculator</h1>
    <p class="tagline">No tax is withheld on 1099 income — estimate what you'll owe and set it aside.</p>
  </section>

  <p>
    If you're paid on a 1099, you owe self-employment tax (15.3% on 92.35% of net
    profit) plus federal and state income tax. This calculator estimates all three.
  </p>

  <QuickEstimator client:load defaultSeIncome={50000} />

  <h2>Choose your state</h2>
  <p>Each state page is built on that state's 2026 income tax rules with a worked example:</p>
  <ul class="link-columns">
    {stateList.map(([code, s]) => (
      <li><a href={`/1099-tax-calculator/${code.toLowerCase()}/`}>1099 taxes in {s.name}</a></li>
    ))}
  </ul>
</Base>
