---
/**
 * Tier-2 paycheck pages: one static page per state. Unique title/meta/H1, a
 * state-specific explanation from verified data, and a worked example computed
 * by the same engine as the island — all present before JavaScript.
 */
import Base from '../../../layouts/Base.astro';
import PaycheckCalculator from '../../../components/calculators/PaycheckCalculator.tsx';
import { states, stateList } from '../../../data/states';
import { paycheckEstimate } from '../../../lib/paycheck';
import { formatMoney, formatPct } from '../../../lib/tax-engine';
import { describeStateTax } from '../../../lib/state-copy';
import { stateSlug } from '../../../lib/slug';
import { siblingStates } from '../../../data/neighbors';
import { describeStateFacts, neighbourComparison, describeNeighbours, neighbourSentences } from '../../../lib/state-facts';
import { getStandardDeduction } from '../../../lib/tax-engine';
import type { StateData } from '../../../data/types';

export function getStaticPaths() {
  return stateList.map(([code, s]) => ({ params: { state: stateSlug(s.name) }, props: { code, state: s } }));
}

interface Props { code: string; state: StateData; }
const { code, state } = Astro.props as Props;

const EXAMPLE = 75000;
const r = paycheckEstimate(EXAMPLE, code, 'single');
const ladder = [45000, 75000, 120000].map((g) => paycheckEstimate(g, code, 'single'));
const facts = describeStateFacts(code, state, 'wages');
const neighbours = neighbourComparison(code, EXAMPLE);
const neighbourSummary = describeNeighbours(code, state, neighbours, EXAMPLE);
const neighbourLines = neighbourSentences(state, neighbours);
const siblings = siblingStates(code, 4).map((c) => states[c]).filter(Boolean);
const noTax = state.noIncomeTax === true || state.type === 'none';

const title = `Paycheck calculator — ${state.name} (2026 take-home pay)`;
const description = `Estimate 2026 take-home pay in ${state.name}: federal income tax, FICA, and ${state.name} state income tax on a W-2 salary. Free calculator with a worked example.`;
---

<Base title={title} description={description}>
  <div class="breadcrumbs">
    <a href="/">Home</a> / <a href="/paycheck-calculator/">Paycheck calculator</a> / {state.name}
  </div>

  <section class="hero">
    <p class="hero-label">2026 tax year · {state.name}</p>
    <h1>{state.name} paycheck calculator</h1>
    <p class="tagline">{describeStateTax(state)}</p>
  </section>

  <PaycheckCalculator client:load presetState={code} defaultGross={EXAMPLE} stateBaseUrl="/paycheck-calculator" />

  <h2>Worked example: {formatMoney(EXAMPLE)} salary in {state.name}</h2>
  <p>A single filer earning {formatMoney(EXAMPLE)} in {state.name}, taking the standard deduction, keeps an estimated:</p>
  <table class="data-table">
    <tbody>
      <tr><td>Federal income tax</td><td>{formatMoney(r.federalTax)}</td></tr>
      <tr><td>FICA (employee share)</td><td>{formatMoney(r.fica)}</td></tr>
      <tr><td>{state.name} state income tax</td><td>{formatMoney(r.stateTax)}</td></tr>
      <tr class="total"><td>Total tax</td><td>{formatMoney(r.totalTax)}</td></tr>
      <tr><td>Effective rate</td><td>{formatPct(r.effectiveRate)}</td></tr>
      <tr class="total"><td>Annual take-home</td><td>{formatMoney(r.takeHome)}</td></tr>
    </tbody>
  </table>

  <div class="callout">
    <strong>Take-home</strong>
    On {formatMoney(EXAMPLE)} in {state.name}, about {formatPct(r.effectiveRate)} goes to
    tax, leaving roughly {formatMoney(r.takeHome)}. Adjust the amount above for your own salary.
  </div>

  <h2>Take-home at three salary levels in {state.name}</h2>
  <table class="data-table">
    <thead>
      <tr><th>Gross salary</th><th>{state.name} income tax</th><th>Total tax</th><th>Take-home</th><th>Effective rate</th></tr>
    </thead>
    <tbody>
      {ladder.map((row) => (
        <tr>
          <td>{formatMoney(row.gross)}</td>
          <td>{noTax ? '—' : formatMoney(row.stateTax)}</td>
          <td>{formatMoney(row.totalTax)}</td>
          <td>{formatMoney(row.takeHome)}</td>
          <td>{formatPct(row.effectiveRate)}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {facts.length > 0 && (
    <>
      <h2>What else comes out of a paycheck in {state.name}</h2>
      {facts.map((p) => <p data-source={`data/states.ts → stateMetadata, ${code}.note`}>{p}</p>)}
    </>
  )}

  <h2>Take-home in the states {state.name} borders</h2>
  {neighbourSummary && <p data-source="lib/tax-engine.ts calcStateTax() + data/adjacency.ts">{neighbourSummary}</p>}
  {neighbours.length > 0 && (
    <table class="data-table">
      <thead>
        <tr><th>State</th><th>State tax on {formatMoney(EXAMPLE)}</th><th>vs {state.name}</th></tr>
      </thead>
      <tbody>
        {neighbours.map((n) => (
          <tr>
            <td><a href={`/paycheck-calculator/${n.slug}/`}>{n.name}</a></td>
            <td>{n.noTax ? 'No income tax' : formatMoney(n.tax)}</td>
            <td>{n.delta === 0 ? 'same' : `${n.delta < 0 ? '−' : '+'}${formatMoney(Math.abs(n.delta))}`}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
  {neighbourLines.length > 0 && (
    <ul>
      {neighbourLines.map((l) => <li data-source="lib/tax-engine.ts calcStateTax()">{l}</li>)}
    </ul>
  )}
  <p>
    If you live on one side of the {state.name} state line and work on the other,
    <a href="/working-in-one-state-living-in-another/"> which state taxes your wages</a> depends on
    whether the two have a reciprocity agreement.
  </p>

  <h2>What this estimate assumes</h2>
  <ul>
    <li>Single filer taking the federal standard deduction of {formatMoney(getStandardDeduction('single'))}; the calculator supports the other three statuses.</li>
    <li>No pre-tax deductions — a 401(k), HSA or health premium taken from gross pay would lower every tax line.</li>
    <li>Employee-side FICA only (7.65%). Your employer pays a matching share you never see.</li>
    <li>No local or municipal income tax, and no state disability withholding beyond what is described above.</li>
    <li>No credits, and no state-specific credits.</li>
  </ul>

  <h2>Related tools</h2>
  <ul class="link-columns">
    <li><a href="/paycheck-calculator/">Paycheck calculator (all states)</a></li>
    <li><a href={`/1099-tax-calculator/${stateSlug(state.name)}/`}>1099 tax calculator for {state.name}</a></li>
    {siblings.map((s) => (
      <li><a href={`/paycheck-calculator/${stateSlug(s!.name)}/`}>{s!.name} paycheck calculator</a></li>
    ))}
  </ul>
</Base>
