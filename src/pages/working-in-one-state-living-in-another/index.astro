---
/**
 * Hub for the cross-border guides. One entry per taxing home state, plus one
 * per work state reachable from a no-income-tax state. Nothing is orphaned.
 */
import Base from '../../layouts/Base.astro';
import { states } from '../../data/states';
import { homeCommutePages, homeCommuteSlug, noTaxHomePages } from '../../lib/state-pair';

const homes = homeCommutePages();
const inbound = new Map(noTaxHomePages().map((e) => [e.workCode, e.homeCodes]));
const total = homes.length;
const name = (c: string) => states[c].name;
---

<Base
  title="Living and working in different states — 2026 state tax guides"
  description="If you live in one state and work in another, which state taxes your wages in 2026? Reciprocity agreements, nonresident returns and credits, worked out for every state."
>
  <section class="hero">
    <p class="hero-label">2026 tax year</p>
    <h1>Living in one state, working in another</h1>
    <p class="tagline">Which state taxes your wages — and how to avoid being taxed twice.</p>
  </section>

  <p>
    Commute across a state line and two tax systems can touch your paycheck. Whether you owe one
    state or both depends on reciprocity agreements and the credit for taxes paid. These {total}
    guides work it out one state at a time, in both directions, with the actual 2026 rates for every
    neighbour.
  </p>

  <h2>Pick the state you live in — or the one you work in</h2>
  <p>
    Each guide covers both directions: commuting out of that state, and commuting into it from a
    neighbour, including from the nine states with no income tax at all.
  </p>
  <ul class="link-columns">
    {homes.map((e) => (
      <li>
        <a href={`/working-in-one-state-living-in-another/${homeCommuteSlug(e.homeCode)}/`}>
          {name(e.homeCode)}{inbound.has(e.homeCode) ? ' ↔' : ''}
        </a>
      </li>
    ))}
  </ul>
  <p style="font-family: var(--mono); font-size: .78rem; color: var(--muted);">
    ↔ also covers commuting in from a no-income-tax neighbour.
  </p>

  <h2>What these guides cover, and what they don't</h2>
  <ul>
    <li>State income tax on wages. Federal tax and FICA are the same wherever you commute.</li>
    <li>Reciprocity agreements cover wages paid by an employer — not self-employment income.</li>
    <li>Local and municipal income tax is called out where the dataset has it, but is not in the figures.</li>
    <li>Worked examples assume a single filer and each state's own rules for 2026.</li>
    <li>Informational only, not tax advice.</li>
  </ul>
</Base>
