---
/**
 * Tier-2 SSG demonstration: one static HTML page per state, generated at build
 * time from src/data via getStaticPaths. Proves the pSEO pattern — unique title,
 * meta, H1, state-specific explanation and a worked example computed from the
 * verified data, all present in the built HTML before any JavaScript runs.
 *
 * NOTE (Phase 1): this is a lean proof of concept, not the finished Tier-2
 * template. The full content contract (assumptions block, 4-6 FAQs, sibling
 * links) lands in Phase 3.
 */
import Base from '../../../layouts/Base.astro';
import QuickEstimator from '../../../components/calculators/QuickEstimator.tsx';
import { stateList } from '../../../data/states';
import { calcCombined, formatMoney, formatPct } from '../../../lib/tax-engine';
import { describeStateTax } from '../../../lib/state-copy';
import type { StateData } from '../../../data/types';

export function getStaticPaths() {
  return stateList.map(([code, s]) => ({
    params: { state: code.toLowerCase() },
    props: { code, state: s },
  }));
}

interface Props {
  code: string;
  state: StateData;
}
const { code, state } = Astro.props as Props;

// Worked example: a representative single filer with $50,000 net 1099 income.
const EXAMPLE_INCOME = 50000;
const r = calcCombined(0, EXAMPLE_INCOME, 0, 'single', code);

const title = `1099 tax calculator — ${state.name} (2026)`;
const description = `Estimate 2026 self-employment, federal, and ${state.name} state income tax on 1099 income. Worked example and free calculator, figures verified from IRS sources.`;
---

<Base title={title} description={description}>
  <p style="font-family: system-ui, sans-serif; font-size: .85rem;">
    <a href="/1099-tax-calculator/">1099 tax calculator</a> / {state.name}
  </p>
  <h1>1099 tax calculator for {state.name} (2026)</h1>

  <p>{describeStateTax(state)}</p>

  <QuickEstimator client:load presetState={code} defaultSeIncome={EXAMPLE_INCOME} />

  <h2>Worked example: {formatMoney(EXAMPLE_INCOME)} of 1099 income in {state.name}</h2>
  <p>
    A single filer with {formatMoney(EXAMPLE_INCOME)} of net 1099 income and no
    W-2 wages, taking the standard deduction, owes an estimated:
  </p>
  <table>
    <tbody>
      <tr><td>Self-employment tax</td><td>{formatMoney(r.seTax)}</td></tr>
      <tr><td>Federal income tax</td><td>{formatMoney(r.fedTax)}</td></tr>
      <tr><td>{state.name} state income tax</td><td>{formatMoney(r.stateTax)}</td></tr>
      <tr><td><strong>Total tax</strong></td><td><strong>{formatMoney(r.totalTax)}</strong></td></tr>
      <tr><td>Effective rate</td><td>{formatPct(r.effectiveRate)}</td></tr>
      <tr><td><strong>After-tax income</strong></td><td><strong>{formatMoney(r.afterTax)}</strong></td></tr>
    </tbody>
  </table>
  <p>
    These figures are computed by the same engine that powers the calculator
    above, from the verified 2026 dataset — so the example can never contradict
    the tool.
  </p>

  <h2>Nearby states</h2>
  <ul style="font-family: system-ui, sans-serif; font-size: .95rem;">
    {stateList
      .filter(([c]) => c !== code)
      .slice(0, 4)
      .map(([c, s]) => (
        <li><a href={`/1099-tax-calculator/${c.toLowerCase()}/`}>1099 taxes in {s.name}</a></li>
      ))}
  </ul>
</Base>
