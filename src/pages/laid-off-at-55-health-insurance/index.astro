import Base from '../../layouts/Base.astro';

const faqItems = [
  { q: `Is COBRA or the marketplace better at 55?`, a: `It depends on your income. Under the 400% FPL cliff, the subsidized marketplace usually beats COBRA even at 55; over the cliff, the unsubsidized marketplace and COBRA are closer, and COBRA's keep-your-plan continuity can win. Run both.`, review: true },
