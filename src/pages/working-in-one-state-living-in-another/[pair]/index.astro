---
/**
 * "Live in one state, work in another" pages — curated high-value set.
 *
 * Generated from highValuePairs(): real commuter corridors (bordering states) +
 * every reciprocity pair + the Arizona WEC pairs (231 pages), rather than the
 * full 2,550 matrix. Each page is genuinely unique: real 2026 rates for both
 * states, the correct arrangement (reciprocity / credit / Arizona WEC /
 * single-state), and a computed worked example — all present before JavaScript.
 */
import Base from '../../../layouts/Base.astro';
import { states } from '../../../data/states';
import { pairOutcome, stateSlug, highValuePairs, noTaxWorkPages, noTaxWorkSlug, noTaxHomePages, noTaxHomeSlug, pairLadder, reciprocityWorth } from '../../../lib/state-pair';
import { formatMoney } from '../../../lib/tax-engine';
import { stateFacts, describeStateFacts } from '../../../lib/state-facts';
import { describeStateLayer, describeStateTax } from '../../../lib/state-copy';

export function getStaticPaths() {
  const pairs = highValuePairs().map(([homeCode, workCode]) => ({
    params: { pair: `living-in-${stateSlug(states[homeCode].name)}-working-in-${stateSlug(states[workCode].name)}` },
    props: { homeCode, workCode, noTaxWork: null },
  }));
  // One collapsed page per home state that borders any no-income-tax state,
  // standing in for what used to be a separate near-identical page per no-tax
  // work state. See noTaxWorkPages() for why.
  const collapsedWork = noTaxWorkPages().map(({ homeCode, workCodes }) => ({
    params: { pair: noTaxWorkSlug(homeCode) },
    props: { homeCode, workCode: workCodes[0], noTaxWork: workCodes, noTaxHome: null },
  }));
  const collapsedHome = noTaxHomePages().map(({ workCode, homeCodes }) => ({
    params: { pair: noTaxHomeSlug(workCode) },
    props: { homeCode: homeCodes[0], workCode, noTaxWork: null, noTaxHome: homeCodes },
  }));
  return [...pairs, ...collapsedWork, ...collapsedHome];
}

interface Props { homeCode: string; workCode: string; noTaxWork: string[] | null; noTaxHome: string[] | null; }
const { homeCode, workCode, noTaxWork, noTaxHome } = Astro.props as Props;
const o = pairOutcome(homeCode, workCode);
// The work state's local income tax is the single most consequential thing a
// cross-border commuter can miss — a New Jersey resident working in New York
// City, or a Delaware resident working in Philadelphia, owes a city tax that
// no reciprocity agreement and no state-level credit touches.
const workLocal = stateFacts(workCode, o.work).localIncomeTax;
const collapsed = Boolean(noTaxWork || noTaxHome);
const ladder = collapsed ? [] : pairLadder(homeCode, workCode);
const worth = !collapsed && o.type === 'reciprocity' ? reciprocityWorth(homeCode, workCode, o.income) : null;
// Home-state detail only. Adding the WORK state's facts made same-work-state
// pairs more alike, not less (they share it); the home state is what separates
// two pages pointing at the same work state.
const detailCode = noTaxHome ? workCode : homeCode;
const detailState = noTaxHome ? o.work : o.home;
const homeLayer = describeStateLayer(detailState, 'wages');
const homeFacts = describeStateFacts(detailCode, detailState, 'wages');
// The reverse commute. This is the one block that belongs to the PAIR rather
// than to either state, so it is what separates two pages that share a home
// state from each other AND two that share a work state.
const reverse = collapsed ? null : pairOutcome(workCode, homeCode, o.income);
const reverseSlug = collapsed ? null
  : `living-in-${stateSlug(o.work.name)}-working-in-${stateSlug(o.home.name)}`;
const reverseExists = collapsed ? false
  : highValuePairs().some(([h, w]) => h === workCode && w === homeCode);

const joinList = (names: string[], conj: 'and' | 'or') => names.length > 1
  ? `${names.slice(0, -1).join(', ')} ${conj} ${names[names.length - 1]}`
  : names[0] ?? '';
const andList = (names: string[]) => joinList(names, 'and');
const orList = (names: string[]) => joinList(names, 'or');
const noTaxNames = (noTaxWork ?? []).map((c) => states[c].name);
const noTaxList = andList(noTaxNames);
const homeNames = (noTaxHome ?? []).map((c) => states[c].name);
const homeList = andList(homeNames);
const homeListOr = orList(homeNames);
const noTaxListOr = orList(noTaxNames);

const title = noTaxWork
  ? `Living in ${o.home.name}, working in a no-income-tax state (2026)`
  : noTaxHome
    ? `Living in a no-income-tax state, working in ${o.work.name} (2026)`
    : `Living in ${o.home.name}, working in ${o.work.name} — 2026 state tax guide`;
const description = noTaxWork
  ? `Live in ${o.home.name} and commute to ${noTaxList}? ${o.home.name} still taxes the wages. What you owe in 2026, with a worked example.`
  : noTaxHome
    ? `Live in ${homeList} and work in ${o.work.name}? Only ${o.work.name} taxes the wages, as a nonresident. What you owe in 2026, with a worked example.`
    : `How state income tax works if you live in ${o.home.name} and work in ${o.work.name} in 2026: ${o.type === 'reciprocity' ? 'reciprocity agreement' : o.type === 'credit' || o.type === 'az-wec' ? 'nonresident return and credit for taxes paid' : 'which state taxes your wages'}, with a worked example.`;
---

<Base title={title} description={description}>
  <div class="breadcrumbs">
    <a href="/">Home</a> / <a href="/working-in-one-state-living-in-another/">Living &amp; working in different states</a> / {noTaxWork ? `${o.home.name} → a no-income-tax state` : noTaxHome ? `a no-income-tax state → ${o.work.name}` : `${o.home.name} → ${o.work.name}`}
  </div>

  <section class="hero">
    <p class="hero-label">2026 tax year · cross-border wages</p>
    <h1>{noTaxWork
      ? `Living in ${o.home.name}, working in a state with no income tax`
      : noTaxHome
        ? `Living in a state with no income tax, working in ${o.work.name}`
        : `Living in ${o.home.name}, working in ${o.work.name}`}</h1>
    <p class="tagline">{noTaxWork
      ? `${o.home.name} taxes its residents on income earned anywhere, so crossing into ${noTaxList} does not make the tax go away.`
      : noTaxHome
        ? `${o.work.name} taxes wages earned inside it whoever earns them, so a resident of ${homeListOr} still files there as a nonresident.`
        : o.headline}</p>
  </section>

  {noTaxWork ? (
    <>
      <p>
        {o.home.name} borders {noTaxNames.length} {noTaxNames.length === 1 ? 'state' : 'states'} with no
        personal income tax — {noTaxList}. The answer is the same for all of them, which is why this is one
        page rather than {noTaxNames.length}: the work state takes nothing, so there is no nonresident
        return to file, no exemption certificate, and no credit to claim. {o.home.name} taxes the wages as
        a resident, exactly as if you had earned them at home.
      </p>
      <p>
        What this does change is withholding. A {noTaxList} employer has no state income tax to withhold,
        so nothing is taken out for {o.home.name} either — the liability is real but nothing is being set
        aside against it. That usually means making {o.home.name} estimated payments during the year, or
        having a spouse's employer withhold extra.
      </p>
    </>
  ) : noTaxHome ? (
    <>
      <p>
        {homeNames.length} of the states bordering {o.work.name} levy no personal income tax —
        {' '}{homeList}. For a resident of any of them the answer is the same, which is why this is one page:
        there is no home-state return to file and no credit to claim, because there is no home-state tax.
        {' '}{o.work.name} taxes the wages earned inside it, and you file there as a nonresident.
      </p>
      <p>
        That makes {o.work.name} the only state in the picture — but it does not make the tax smaller. On
        {' '}{formatMoney(o.income)} of wages the {o.work.name} bill is {formatMoney(o.workTax)}, and living
        across a border that charges nothing does not reduce it by a cent.
      </p>
    </>
  ) : (
    <p>{o.explanation}</p>
  )}

  {o.exemptionForm && (
    <div class="callout">
      <strong>Exemption form</strong>
      File <strong>{o.exemptionForm}</strong> — {o.work.name}'s nonresident certificate — with your
      {' '}{o.work.name} employer to stop {o.work.name} withholding on your wages.
    </div>
  )}

  <h2>Worked example: {formatMoney(o.income)} of wages</h2>
  <p>A single filer living in {noTaxHome ? homeListOr : o.home.name} and working in {noTaxWork ? noTaxListOr : o.work.name}, earning {formatMoney(o.income)}, owes an estimated:</p>
  <table class="data-table">
    <tbody>
      <tr><td>{noTaxWork ? 'Work state tax (no income tax)' : `${o.work.name} tax (work state)`}</td><td>{formatMoney(o.workTax)}</td></tr>
      <tr><td>{noTaxHome ? 'Home state tax (no income tax)' : `${o.home.name} tax before credit (home state)`}</td><td>{formatMoney(o.homeTaxBeforeCredit)}</td></tr>
      {o.credit > 0 && <tr><td>Credit for taxes paid to {o.work.name}</td><td>−{formatMoney(o.credit)}</td></tr>}
      <tr class="total"><td>Total state income tax</td><td>{formatMoney(o.totalStateTax)}</td></tr>
    </tbody>
  </table>
  <p style="font-family: var(--mono); font-size: .78rem; color: var(--muted);">
    State income tax on wages only, 2026 rates. Not tax advice —
    <a href="/working-in-one-state-living-in-another/">what this does and doesn't cover</a>.
  </p>

  {homeLayer.length > 0 && (
    <>
      <h2>{noTaxHome ? `What ${o.work.name} charges as the work state` : `What ${o.home.name} charges as your home state`}</h2>
      {homeLayer.map((p) => <p data-source={`data/states.ts → ${detailCode}`}>{p}</p>)}
      {homeFacts.map((p) => <p data-source={`data/states.ts → stateMetadata, ${detailCode}.note`}>{p}</p>)}
    </>
  )}

  {ladder.length > 0 && (
    <>
      <h2>The same commute at three salaries</h2>
      <table class="data-table">
        <thead>
          <tr><th>Wages</th><th>{o.work.name}</th><th>{o.home.name}</th><th>Total state tax</th></tr>
        </thead>
        <tbody>
          {ladder.map((row) => (
            <tr>
              <td>{formatMoney(row.income)}</td>
              <td>{formatMoney(row.workTax)}</td>
              <td>{formatMoney(row.homeTaxAfterCredit)}</td>
              <td>{formatMoney(row.totalStateTax)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  {worth && (
    <>
      <h2>What the {o.home.name}–{o.work.name} agreement is actually worth</h2>
      <p data-source={`data/states.ts → ${workCode}`}>{describeStateTax(o.work)}</p>
      <p data-source="lib/tax-engine.ts calcStateTax() + data/reciprocity.ts">
        Without it you would pay {o.work.name} {formatMoney(worth.workTax)} as a nonresident and then
        claim a credit on your {o.home.name} return, landing at {formatMoney(worth.withoutAgreement)} —
        {worth.cashDifference === 0
          ? ' the same total you pay now.'
          : ` ${formatMoney(Math.abs(worth.cashDifference))} ${worth.cashDifference > 0 ? 'more' : 'less'} than the ${formatMoney(worth.homeTax)} you pay with it.`}
        {worth.cashDifference === 0
          ? ' The agreement saves you the second return and the year-long cash-flow gap, rather than tax.'
          : ''}
      </p>
    </>
  )}

  {!collapsed && (o.type === 'credit' || o.type === 'az-wec') && (
    <>
      <h2>What {o.work.name} charges as the work state</h2>
      <p data-source={`data/states.ts → ${workCode}`}>{describeStateTax(o.work)}</p>
      <p data-source="lib/tax-engine.ts calcStateTax()">
        On {formatMoney(o.income)} that is {formatMoney(o.workTax)} to {o.work.name}, against
        {' '}{formatMoney(o.homeTaxBeforeCredit)} of {o.home.name} tax before the credit. Because the
        credit is capped at your {o.home.name} liability, the state that ends up governing what you pay
        is {o.workTax >= o.homeTaxBeforeCredit ? o.work.name : o.home.name}.
      </p>
    </>
  )}

  {reverse && (
    <>
      <h2>The same border, the other way round</h2>
      <p data-source="lib/tax-engine.ts calcStateTax()">
        {reverse.totalStateTax === o.totalStateTax
          ? `Commuting the other way — living in ${o.work.name} and working in ${o.home.name} — comes to the same ${formatMoney(o.totalStateTax)} on ${formatMoney(o.income)}. Which side of the line you sleep on does not change the bill for this pair.`
          : `Living in ${o.work.name} and working in ${o.home.name} instead would cost ${formatMoney(reverse.totalStateTax)} on the same ${formatMoney(o.income)}, against ${formatMoney(o.totalStateTax)} for this direction — a difference of ${formatMoney(Math.abs(reverse.totalStateTax - o.totalStateTax))}. Your residence, not your workplace, is what drives it.`}
        {reverseExists && (
          <> <a href={`/working-in-one-state-living-in-another/${reverseSlug}/`}>See the {o.work.name} → {o.home.name} direction</a>.</>
        )}
      </p>
    </>
  )}

  {workLocal && (
    <div class="callout">
      <strong>Local tax in {o.work.name}</strong>
      The figures above are state income tax only. {o.work.name} also has local income tax —
      {' '}{workLocal.join('; ')} — and a local tax is generally owed where the work is performed,
      whatever the two states have agreed between themselves. Check the city or county you
      actually work in.
    </div>
  )}

</Base>
